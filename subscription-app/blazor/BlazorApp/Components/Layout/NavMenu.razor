@using Microsoft.AspNetCore.Components.Routing
@namespace BlazorApp.Components.Layout

@code {
    [Parameter]
    public EventCallback OnClose { get; set; }

    private async Task HandleClick()
    {
        await OnClose.InvokeAsync();
    }
}

<div class="flex flex-col h-full py-4">
    <div class="px-3 mb-6">
        <span class="text-lg font-bold text-foreground">Subscription Audit</span>
    </div>

    <nav class="flex-1 px-2 space-y-1">
        <div class="px-1">
            <NavLink href="" Match="NavLinkMatch.All" class="dashboard-link" @onclick="HandleClick">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="7" height="9" x="3" y="3" rx="1" />
                    <rect width="7" height="5" x="14" y="3" rx="1" />
                    <rect width="7" height="9" x="14" y="12" rx="1" />
                    <rect width="7" height="5" x="3" y="16" rx="1" />
                </svg>
                Dashboard
            </NavLink>
        </div>

        <div class="px-1">
            <NavLink href="subscriptions" class="subscriptions-link" @onclick="HandleClick">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 8V21H3V8" />
                    <path d="M1 3H23V8H1Z" />
                    <path d="M10 12H14" />
                </svg>
                Subscriptions
            </NavLink>
        </div>

        <div class="px-1">
            <NavLink href="settings" class="settings-link" @onclick="HandleClick">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
                    <circle cx="12" cy="12" r="3" />
                </svg>
                Settings
            </NavLink>
        </div>
    </nav>
</div>

        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.375rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: #4B5563;
        text-decoration: none;
        transition: background-color 0.15s, color 0.15s;
    }

    .nav-link:hover {
        background-color: #F9FAFB;
        color: #111827;
    }

    .nav-link.active {
